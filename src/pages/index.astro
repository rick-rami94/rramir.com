---
import Base from '../layouts/Base.astro';
import {
  profile,
  credentials,
  languages,
  focusAreas,
  experience,
  standards,
  certifications,
  education,
  projects,
  services,
} from '../data/site.js';
---

<Base>
  <!-- Nav -->
  <header class="nav">
    <div class="container nav-inner">
      <a class="nav-logo" href="#top">rramir<span class="dot">.</span>com</a>
      <nav>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#services">Consulting</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="hero-eyebrow"><span class="pulse"></span> {profile.role}</span>
        <h1>
          {profile.name}<span class="accent">.</span>
        </h1>
        <p class="hero-tagline">{profile.tagline}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#contact">Get in touch</a>
          <a class="btn btn-ghost" href={profile.linkedin} target="_blank" rel="noopener">
            LinkedIn ↗
          </a>
          <a class="btn btn-ghost" href={profile.github} target="_blank" rel="noopener">
            GitHub ↗
          </a>
        </div>
        <div class="hero-creds">
          {
            credentials.map((c) => (
              <span class="cred">
                {c.icon === 'mic' && (
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                    <line x1="12" y1="19" x2="12" y2="23" />
                  </svg>
                )}
                {c.icon === 'award' && (
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="8" r="6" />
                    <path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5" />
                  </svg>
                )}
                <strong>{c.label}</strong>
                <em>{c.sub}</em>
              </span>
            ))
          }
        </div>
      </div>
      <div class="hero-portrait">
        <img
          src="/portrait.jpeg"
          width="400"
          height="400"
          alt={`Portrait of ${profile.name}`}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="section-label reveal">// about</p>
      <h2 class="section-title reveal">From risk methodology to working systems</h2>
      <p class="section-lead reveal">{profile.intro}</p>

      <div class="grid grid-3">
        {
          focusAreas.map((f) => (
            <div class="card focus-card reveal">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))
        }
      </div>

      <div class="tag-list reveal">
        {standards.map((s) => <span class="tag">{s}</span>)}
      </div>

      <div class="languages reveal">
        <span class="lang-label">Languages</span>
        <span class="lang-list">{languages.join(' · ')}</span>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <p class="section-label reveal">// experience</p>
      <h2 class="section-title reveal">Where I've worked</h2>
      {
        experience.map((co) => (
          <div class="exp-co reveal">
            <div class="exp-co-head">
              <h3 class="exp-co-name">{co.org}</h3>
              {co.meta && <span class="exp-co-meta">{co.meta}</span>}
            </div>
            <div class="exp-roles">
              {co.roles.map((r) => (
                <div class="exp-item">
                  <div class="exp-head">
                    <span class="exp-role">{r.role}</span>
                    <span class="exp-period">{r.period}</span>
                  </div>
                  {r.points.length > 0 && (
                    <ul class="exp-points">
                      {r.points.map((p) => (
                        <li>{p}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications">
    <div class="container">
      <p class="section-label reveal">// certifications</p>
      <h2 class="section-title reveal">Certifications</h2>
      <div class="cert-groups">
        {
          certifications.map((g) => (
            <div class="cert-group reveal">
              <h3 class="cert-group-title">{g.group}</h3>
              <div class="cert-list">
                {g.items.map((c) => (
                  <div class="cert-card">
                    <div class="cert-top">
                      <span class="cert-name">{c.name}</span>
                      {c.note && (
                        <span class={`cert-note${c.note === 'In progress' ? ' is-progress' : ''}`}>
                          {c.note}
                        </span>
                      )}
                    </div>
                    <span class="cert-issuer">{c.issuer}</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education">
    <div class="container">
      <p class="section-label reveal">// education</p>
      <h2 class="section-title reveal">Education</h2>
      <div class="edu-list reveal">
        {
          education.map((e) => (
            <div class="edu-item">
              <div class="edu-main">
                <span class="edu-school">{e.school}</span>
                <span class="edu-detail">{e.detail}</span>
              </div>
              <span class="edu-period">{e.period}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <p class="section-label reveal">// projects</p>
      <h2 class="section-title reveal">Things I've built</h2>
      <p class="section-lead reveal">
        Security-first tools across OT/ICS risk assessment and AI agent systems —
        built to be auditable, governed, and honest about their limits.
      </p>

      <div class="grid grid-2">
        {
          projects.map((p) => (
            <div class="card proj-card reveal">
              <span class="proj-tag">{p.tag}</span>
              <h3>{p.name}</h3>
              <p>{p.blurb}</p>
              <div class="proj-stack">
                {p.stack.map((s) => (
                  <span>{s}</span>
                ))}
              </div>
              {p.link ? (
                <a class="proj-link" href={p.link} target="_blank" rel="noopener">
                  {p.linkLabel} ↗
                </a>
              ) : (
                <span class="proj-link disabled">{p.linkLabel}</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Services / Consulting -->
  <section id="services">
    <div class="container">
      <p class="section-label reveal">// consulting</p>
      <h2 class="section-title reveal">Cybersecurity risk consulting</h2>
      <p class="section-lead reveal">
        Independent, standards-aligned assessment that turns a sprawling environment
        into a clear, prioritized view of cyber risk — and a plan to reduce it.
      </p>

      <div class="grid grid-3">
        {
          services.map((s) => (
            <div class="card reveal">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          ))
        }
      </div>

      <div class="services-cta reveal">
        <a class="btn btn-primary" href="#contact">Work with me →</a>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <div class="card reveal">
        <h2>Let's talk</h2>
        <p>
          Open to consulting engagements and conversations about OT/ICS risk,
          product security, and security-first AI. The fastest way to reach me is email.
        </p>
        <div class="contact-actions">
          <a class="btn btn-primary" href={`mailto:${profile.email}`}>{profile.email}</a>
          <a class="btn btn-ghost" href={profile.linkedin} target="_blank" rel="noopener">
            LinkedIn ↗
          </a>
          <a class="btn btn-ghost" href={profile.github} target="_blank" rel="noopener">
            GitHub ↗
          </a>
        </div>
        <p class="contact-note">
          Looking for my résumé? Email me and I’ll send it over.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <span>© {new Date().getFullYear()} {profile.name}</span>
      <div class="footer-links">
        <a href={profile.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={profile.github} target="_blank" rel="noopener">GitHub</a>
        <a href={`mailto:${profile.email}`}>Email</a>
      </div>
      <span class="mono">rramir.com</span>
    </div>
  </footer>
</Base>
